# Composio API key: https://app.composio.dev/settings
COMPOSIO_API_KEY=
# The "slackbot" auth config the bot connects through (ac_...)
COMPOSIO_SLACKBOT_AUTH_CONFIG_ID=
# Slack app signing secret, verifies interactivity requests
SLACK_SIGNING_SECRET=
# Shared secret the Vercel cron sends as `Authorization: Bearer <CRON_SECRET>`
CRON_SECRET=
