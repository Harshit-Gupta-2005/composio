# Composio API Configuration
COMPOSIO_API_KEY=your_api_key_here
COMPOSIO_API_BASE=https://backend.composio.dev/api/v3

# OpenAPI Spec URL for API Reference
OPENAPI_SPEC_URL=https://backend.composio.dev/api/v3/openapi.json

# Docs sidebar agent model (Inception Labs Mercury by default)
DOCS_AGENT_MODEL_FLOW=mercury
INCEPTION_API_KEY=your_inception_api_key_here
# INCEPTION_MODEL=mercury-2
# INCEPTION_BASE_URL=https://api.inceptionlabs.ai/v1
# DOCS_AGENT_MODEL_FLOW=gateway
# DOCS_AGENT_GATEWAY_MODEL=openai/gpt-5.4-mini
# DOCS_AGENT_EAGER_SEARCH=0 # disable automatic pre-model docs retrieval; enabled by default
# DOCS_AGENT_SEARCH_PERF_LOG=1
# DOCS_AGENT_SEARCH_LOG_QUERY=1 # includes raw user queries in server logs; avoid in production

# PostHog Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Slack webhook for docs feedback (create at https://api.slack.com/apps)
SLACK_FEEDBACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx
